# URL base del backend FastAPI (incluye prefijo /api/v1).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Tenant del restaurante enviado en header X-Restaurant-Id.
NEXT_PUBLIC_RESTAURANT_ID=frittes-maison

# Dominio de Plausible para analytics (opcional).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# DSN publico de Sentry para captura de errores (opcional).
NEXT_PUBLIC_SENTRY_DSN=
